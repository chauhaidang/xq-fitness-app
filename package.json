{
  "name": "xq-fitness-mobile",
  "version": "2.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "E2E=true ENABLE_API_LOGGING=true expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathIgnorePatterns=integration",
    "test:integration": "GATEWAY_URL=http://localhost:8080 jest --config=jest.integration.config.js --reporters=default --reporters=jest-junit",
    "test:integration:watch": "GATEWAY_URL=http://localhost:8080 jest --config=jest.integration.config.js --watch",
    "test:all": "yarn test:unit && yarn test:integration",
    "test:e2e": "wdio run ./e2e/config/wdio.conf.ts",
    "mock:api": "prism mock api/read-service-api.yaml api/write-service-api.yaml --errors",
    "download:api": "rm -rf xq-apis/ && ./scripts/download-api-files.sh",
    "bip": "E2E=true GATEWAY_URL=http://localhost:8080 expo prebuild --no-install --platform ios && ./scripts/strip-ios-capabilities.sh && cp build-sim.sh ios/build-sim.sh && chmod +x ios/build-sim.sh && cp build-device.sh ios/build-device.sh && chmod +x ios/build-device.sh",
    "bi": "cd ios && pod update && pod install && E2E=true GATEWAY_URL=http://localhost:8080 sh ./build-sim.sh && cd ..",
    "deploy-sim": "./deploy-sim.sh",
    "build-and-deploy": "yarn bi && yarn deploy-sim",
    "ls-device": "xcrun simctl list devices available",
    "bid": "unset E2E && GATEWAY_URL='https://xq-fitness-udfuy.ondigitalocean.app' cd ios && pod update && pod install && sh ./build-device.sh",
    "deploy-device": "ios-deploy -b ios/build/Export/XQFitness.ipa",
    "copy-app": "rm -rf build && mkdir -p build && cp -r ./ios/build/Products/Release-iphonesimulator/XQFitness.app ./build/XQFitness.app",
    "e2e:analyze-dom": "tsx e2e/scripts/analyze-dom-trees.ts",
    "e2e:install-app": "xcrun simctl install 9D4D7315-746B-47BF-A531-2B2E0E9EDD7D ./e2e/XQFitness.app",
    "e2e:generate-client": "./e2e/scripts/generate-api-client.sh"
  },
  "dependencies": {
    "@expo/webpack-config": "^19.0.0",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@types/react": "~18.2.14",
    "@wdio/devtools-service": "^10.1.0",
    "axios": "^1.6.2",
    "expo": "~49.0.15",
    "expo-dev-client": "~2.4.13",
    "expo-splash-screen": "~0.20.5",
    "expo-status-bar": "~1.6.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.72.10",
    "react-native-gesture-handler": "~2.12.0",
    "react-native-safe-area-context": "4.6.3",
    "react-native-screens": "~3.22.0",
    "react-native-web": "~0.19.6"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@chauhaidang/xq-common-kit": "^1.0.12",
    "@stoplight/prism-cli": "^5.4.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "@wdio/cli": "^9.23.3",
    "@wdio/globals": "^9.17.0",
    "@wdio/local-runner": "^9.21.0",
    "@wdio/mocha-framework": "^9.21.0",
    "@wdio/spec-reporter": "^9.20.0",
    "appium-xcuitest-driver": "^10.9.0",
    "cors": "^2.8.5",
    "detox": "^20.14.0",
    "dotenv": "^16.6.1",
    "expect-webdriverio": "^5.5.0",
    "expo-build-properties": "0.8.3",
    "express": "^4.18.2",
    "jest": "^30.2.0",
    "jest-circus": "^30.2.0",
    "jest-expo": "~49.0.0",
    "jest-junit": "^16.0.0",
    "pg": "^8.20.0",
    "react-test-renderer": "^18.2.0",
    "xq-fitness-read-client": "file:./e2e/generated-clients/read-service",
    "xq-fitness-write-client": "file:./e2e/generated-clients/write-service"
  },
  "private": true,
  "jest-junit": {
    "outputDirectory": "./__tests__/integration/tsr",
    "outputName": "junit.xml",
    "usePathForSuiteName": "true"
  }
}
