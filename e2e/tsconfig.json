{
    "compilerOptions": {
        "moduleResolution": "node",
        "module": "commonjs",
        "esModuleInterop": true,
        "target": "es2022",
        "lib": [
            "es2022",
            "dom"
        ],
        "types": [
            "node",
            "jest"
        ],
        "skipLibCheck": true,
        "noEmit": true,
        "resolveJsonModule": true,
        "strict": false
    },
    "include": [
        "tests",
        "tests/api",
        "config",
        "page-objects",
        "support",
        "scripts",
        "types"
    ]
}
